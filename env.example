import { GoogleGenAI, Type, Modality, GenerateContentResponse, FunctionDeclaration } from "@google/genai";

const apiKey = process.env.GEMINI_API_KEY;
if (!apiKey) {
  console.error("GEMINI_API_KEY is not set.");
}

const ai = new GoogleGenAI({ apiKey: apiKey || "" });

export async function extractExpenseFromReceipt(base64Image: string, mimeType: string) {
  try {
    const response = await ai.models.generateContent({
      model: "gemini-3-flash-preview",
      contents: [
        {
          parts: [
            { text: "Extract expense details from this receipt. Return JSON with fields: amount (number), currency (string, e.g. USD), category (string), description (string), date (string, YYYY-MM-DD), merchantName (string)." },
            { inlineData: { data: base64Image, mimeType } }
          ]
        }
      ],
      config: {
        responseMimeType: "application/json",
        responseSchema: {
          type: Type.OBJECT,
          properties: {
            amount: { type: Type.NUMBER },
            currency: { type: Type.STRING },
            category: { type: Type.STRING },
            description: { type: Type.STRING },
            date: { type: Type.STRING },
            merchantName: { type: Type.STRING }
          },
          required: ["amount", "currency", "category", "description", "date", "merchantName"]
        }
      }
    });

    const text = response.text;
    if (text) {
      return JSON.parse(text);
    }
    return null;
  } catch (error) {
    console.error("OCR Error:", error);
    return null;
  }
}

const navigateToFunctionDeclaration: FunctionDeclaration = {
  name: "navigateTo",
  description: "Navigate to a specific page in the application.",
  parameters: {
    type: Type.OBJECT,
    properties: {
      page: {
        type: Type.STRING,
        description: "The page to navigate to. Options: 'dashboard', 'expenses', 'approvals', 'team', 'settings', 'new_expense'.",
        enum: ['dashboard', 'expenses', 'approvals', 'team', 'settings', 'new_expense']
      }
    },
    required: ["page"]
  }
};

export async function startVoiceConversation(callbacks: {
  onopen: () => void;
  onmessage: (message: any) => void;
  onerror: (error: any) => void;
  onclose: () => void;
}) {
  try {
    const session = await ai.live.connect({
      model: "gemini-3.1-flash-live-preview",
      callbacks: {
        onopen: callbacks.onopen,
        onmessage: callbacks.onmessage,
        onerror: callbacks.onerror,
        onclose: callbacks.onclose,
      },
      config: {
        responseModalities: [Modality.AUDIO],
        tools: [{ functionDeclarations: [navigateToFunctionDeclaration] }],
        speechConfig: {
          voiceConfig: { prebuiltVoiceConfig: { voiceName: "Zephyr" } },
        },
        systemInstruction: "You are a helpful assistant for a Reimbursement Management app. You can help users submit expenses, check status, and navigate the app. You can also provide information about approval rules. Keep your responses concise and professional. Use the 'navigateTo' tool when the user wants to go to a specific section of the app.",
      },
    });
    return session;
  } catch (error) {
    console.error("Voice Session Error:", error);
    return null;
  }
}
