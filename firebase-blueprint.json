import React, { useState, useEffect } from 'react';
import { motion } from 'motion/react';
import { 
  Users, 
  UserPlus, 
  Search, 
  Filter, 
  MoreVertical, 
  Shield, 
  UserCircle, 
  Mail,
  ChevronRight,
  Plus,
  ArrowRight
} from 'lucide-react';
import { db, handleFirestoreError, OperationType } from '../firebase';
import { collection, query, where, onSnapshot, doc, setDoc, serverTimestamp } from 'firebase/firestore';

interface TeamManagementProps {
  user: any;
  company: any;
}

export default function TeamManagement({ user, company }: TeamManagementProps) {
  const [members, setMembers] = useState<any[]>([]);
  const [showAddMember, setShowAddMember] = useState(false);
  const [newMember, setNewMember] = useState({
    name: '',
    email: '',
    role: 'employee',
    managerId: ''
  });

  useEffect(() => {
    const q = query(
      collection(db, 'users'),
      where('companyId', '==', user.companyId)
    );

    const unsubscribe = onSnapshot(q, (snapshot) => {
      const memberData = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
      setMembers(memberData);
    }, (e) => handleFirestoreError(e, OperationType.LIST, 'users'));

    return () => unsubscribe();
  }, [user.companyId]);

  const handleAddMember = async (e: React.FormEvent) => {
    e.preventDefault();
    try {
      const memberId = doc(collection(db, 'users')).id;
      const memberPath = `users/${memberId}`;
      await setDoc(doc(db, 'users', memberId), {
        ...newMember,
        companyId: user.companyId,
        createdAt: serverTimestamp(),
      }).catch(e => handleFirestoreError(e, OperationType.WRITE, memberPath));
      setShowAddMember(false);
      setNewMember({ name: '', email: '', role: 'employee', managerId: '' });
    } catch (error) {
      console.error("Add Member Error:", error);
    }
  };

  const managers = members.filter(m => m.role === 'manager' || m.role === 'admin');

  return (
    <div className="space-y-8">
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-3xl font-bold text-white mb-2">Team Management</h1>
          <p className="text-gray-400">Manage roles, hierarchies, and access permissions for your organization.</p>
        </div>
        <button 
          onClick={() => setShowAddMember(true)}
          className="px-6 py-3 bg-[#ff4e00] hover:bg-[#e64600] text-white font-bold rounded-xl transition-all shadow-lg shadow-[#ff4e00]/20 flex items-center gap-2"
        >
          <UserPlus className="w-5 h-5" />
          Add Team Member
        </button>
      </div>

      <div className="grid grid-cols-1 lg:grid-cols-4 gap-6">
        <div className="bg-[#151619] border border-white/5 rounded-2xl p-6">
          <p className="text-[10px] text-gray-500 uppercase tracking-widest font-bold mb-1">Total Members</p>
          <p className="text-2xl font-bold text-white">{members.length}</p>
          <p className="text-[10px] text-green-500 font-bold uppercase tracking-widest mt-2">+12% this month</p>
        </div>
        <div className="bg-[#151619] border border-white/5 rounded-2xl p-6">
          <p className="text-[10px] text-gray-500 uppercase tracking-widest font-bold mb-1">Pending Invites</p>
          <p className="text-2xl font-bold text-white">42</p>
          <p className="text-[10px] text-gray-600 font-bold uppercase tracking-widest mt-2">Awaiting activation</p>
        </div>
        <div className="bg-[#151619] border border-white/5 rounded-2xl p-6">
          <p className="text-[10px] text-gray-500 uppercase tracking-widest font-bold mb-1">Roles Assigned</p>
          <p className="text-2xl font-bold text-white">3 Types</p>
          <p className="text-[10px] text-blue-500 font-bold uppercase tracking-widest mt-2">Admin, Manager, Employee</p>
        </div>
        <div className="bg-[#151619] border border-white/5 rounded-2xl p-6">
          <p className="text-[10px] text-gray-500 uppercase tracking-widest font-bold mb-1">Uptime & Sync</p>
          <p className="text-2xl font-bold text-white">99.8%</p>
          <p className="text-[10px] text-gray-600 font-bold uppercase tracking-widest mt-2">System health active</p>
        </div>
      </div>

      <div className="bg-[#151619] border border-white/5 rounded-2xl overflow-hidden">
        <div className="p-6 border-b border-white/5 flex items-center justify-between">
          <div className="relative flex-1 max-w-md">
            <Search className="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500" />
            <input 
              type="text" 
              placeholder="Search by name, email or role..."
              className="w-full bg-white/5 border border-white/10 rounded-xl pl-12 pr-4 py-2.5 text-sm focus:outline-none focus:border-[#ff4e00] transition-colors"
            />
          </div>
          <button className="p-2.5 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 transition-colors">
            <Filter className="w-5 h-5 text-gray-400" />
          </button>
        </div>

        <div className="overflow-x-auto">
          <table className="w-full text-left">
            <thead>
              <tr className="text-[10px] text-gray-500 uppercase tracking-widest font-bold border-b border-white/5">
                <th className="px-6 py-4">Employee</th>
                <th className="px-6 py-4">Current Role</th>
                <th className="px-6 py-4">Reporting To</th>
                <th className="px-6 py-4 text-right">Actions</th>
              </tr>
            </thead>
            <tbody className="divide-y divide-white/5">
              {members.map((member) => (
                <tr key={member.id} className="hover:bg-white/5 transition-colors group">
                  <td className="px-6 py-4">
                    <div className="flex items-center gap-3">
                      <div className="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center font-bold text-gray-400">
                        {member.name[0]}
                      </div>
                      <div>
                        <h4 className="text-sm font-bold text-white">{member.name}</h4>
                        <p className="text-xs text-gray-500">{member.email}</p>
                      </div>
                    </div>
                  </td>
                  <td className="px-6 py-4">
                    <span className={`px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest ${
                      member.role === 'admin' ? 'bg-[#ff4e00]/10 text-[#ff4e00]' :
                      member.role === 'manager' ? 'bg-blue-500/10 text-blue-500' :
                      'bg-gray-500/10 text-gray-400'
                    }`}>
                      {member.role}
                    </span>
                  </td>
                  <td className="px-6 py-4">
                    <div className="flex items-center gap-2">
                      <div className="w-6 h-6 rounded-full bg-white/5 flex items-center justify-center">
                        <UserCircle className="w-4 h-4 text-gray-600" />
                      </div>
                      <span className="text-sm text-gray-400">
                        {members.find(m => m.uid === member.managerId)?.name || 'Direct Report to Board'}
                      </span>
                    </div>
                  </td>
                  <td className="px-6 py-4 text-right">
                    <button className="p-2 hover:bg-white/10 rounded-lg transition-colors">
                      <MoreVertical className="w-4 h-4 text-gray-500" />
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      {/* Add Member Modal */}
      {showAddMember && (
        <div className="fixed inset-0 bg-black/80 backdrop-blur-sm z-50 flex items-center justify-center p-4">
          <motion.div 
            initial={{ opacity: 0, scale: 0.95 }}
            animate={{ opacity: 1, scale: 1 }}
            className="max-w-md w-full bg-[#151619] border border-white/10 rounded-3xl p-8 shadow-2xl"
          >
            <div className="flex items-center justify-between mb-8">
              <h3 className="text-2xl font-bold text-white">Invite Team Member</h3>
              <button onClick={() => setShowAddMember(false)} className="p-2 hover:bg-white/5 rounded-full">
                <X className="w-6 h-6 text-gray-500" />
              </button>
            </div>

            <form onSubmit={handleAddMember} className="space-y-6">
              <div className="space-y-2">
                <label className="text-xs font-bold text-gray-500 uppercase tracking-widest">Full Name</label>
                <input 
                  type="text" 
                  required
                  value={newMember.name}
                  onChange={(e) => setNewMember({ ...newMember, name: e.target.value })}
                  className="w-full bg-[#0a0502] border border-white/5 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[#ff4e00] transition-colors"
                  placeholder="Elena Huber"
                />
              </div>
              <div className="space-y-2">
                <label className="text-xs font-bold text-gray-500 uppercase tracking-widest">Email Address</label>
                <input 
                  type="email" 
                  required
                  value={newMember.email}
                  onChange={(e) => setNewMember({ ...newMember, email: e.target.value })}
                  className="w-full bg-[#0a0502] border border-white/5 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[#ff4e00] transition-colors"
                  placeholder="elena@company.com"
                />
              </div>
              <div className="grid grid-cols-2 gap-4">
                <div className="space-y-2">
                  <label className="text-xs font-bold text-gray-500 uppercase tracking-widest">Default Role</label>
                  <select 
                    value={newMember.role}
                    onChange={(e) => setNewMember({ ...newMember, role: e.target.value })}
                    className="w-full bg-[#0a0502] border border-white/5 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[#ff4e00] transition-colors"
                  >
                    <option value="employee">Employee</option>
                    <option value="manager">Manager</option>
                    <option value="admin">Admin</option>
                  </select>
                </div>
                <div className="space-y-2">
                  <label className="text-xs font-bold text-gray-500 uppercase tracking-widest">Reporting To</label>
                  <select 
                    value={newMember.managerId}
                    onChange={(e) => setNewMember({ ...newMember, managerId: e.target.value })}
                    className="w-full bg-[#0a0502] border border-white/5 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[#ff4e00] transition-colors"
                  >
                    <option value="">Select Manager</option>
                    {managers.map(m => (
                      <option key={m.uid} value={m.uid}>{m.name}</option>
                    ))}
                  </select>
                </div>
              </div>

              <button 
                type="submit"
                className="w-full py-4 bg-[#ff4e00] hover:bg-[#e64600] text-white font-bold rounded-xl transition-all shadow-lg shadow-[#ff4e00]/20 flex items-center justify-center gap-2"
              >
                Send Invites
                <ArrowRight className="w-5 h-5" />
              </button>
            </form>
          </motion.div>
        </div>
      )}
    </div>
  );
}

import { X } from 'lucide-react';
